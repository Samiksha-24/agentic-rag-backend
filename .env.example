# ---------------------------------------------------------------------------
# Legacy Streamlit entry points ONLY (app.py = OpenAI demo, app_deep_seek.py /
# app_llama3.2.py = local-LLM demos, crew.py/main.py = CrewAI CLI boilerplate).
# None of these are used by the FastAPI backend (see the API section below) --
# the deployed API only supports Gemini/Groq. Leave these blank if you're not
# running the legacy Streamlit apps.
# ---------------------------------------------------------------------------
MODEL=your_model_name
OPENAI_API_KEY=your_openai_api_key
SERPER_API_KEY=your_serper_api_key
FIRECRAWL_API_KEY=your_firecrawl_api_key
# Optional override for crew.py's legacy single-PDF CLI entrypoint (was hardcoded before)
PDF_TOOL_PATH=

# ---------------------------------------------------------------------------
# FastAPI backend (src/agentic_rag/api) -- this is what gets deployed.
# ---------------------------------------------------------------------------
ENVIRONMENT=development
LOG_LEVEL=INFO

# LLM_PROVIDER: gemini | groq  -- REQUIRED, no OpenAI/Ollama fallback.
LLM_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini/gemini-2.0-flash
GROQ_API_KEY=
GROQ_MODEL=groq/llama-3.3-70b-versatile

# WEB_SEARCH_PROVIDER: serper (uses SERPER_API_KEY above) | firecrawl (uses FIRECRAWL_API_KEY) | none
WEB_SEARCH_PROVIDER=serper

# Vector store: local on-disk path so the index survives restarts.
# Leave blank to use an in-memory (session-only) index instead.
QDRANT_PERSIST_DIR=./qdrant_storage

# Hybrid retrieval (dense Qdrant + BM25, fused with reciprocal rank fusion)
RETRIEVAL_TOP_K=5
RETRIEVAL_FETCH_K=20
USE_RERANKER=true
RERANKER_MODEL=BAAI/bge-reranker-base

# Uploads
MAX_UPLOAD_MB=25

# Comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:8080

RESEARCH_MODE_DEFAULT=false
